# DB_PATH=/data/research-agent.db
# Locally: leave blank (defaults to research-agent.db in project root)
DB_PATH=

# ── rate limits (optional) ────────────────────────────────────────────────────
RESEARCH_RATE_LIMIT_PER_MINUTE=5
INGEST_RATE_LIMIT_PER_HOUR=3

